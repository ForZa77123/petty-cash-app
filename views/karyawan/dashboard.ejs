<%- include('../partials/header', { pageTitle: 'Dashboard Saya', activePage: 'dashboard' }) %>

<% if (flash.success && flash.success.length > 0) { %>
  <div class="alert-success mb-4"><i class="bi bi-check-circle me-2"></i><%= flash.success %></div>
<% } %>
<% if (flash.error && flash.error.length > 0) { %>
  <div class="alert-error mb-4"><i class="bi bi-exclamation-circle me-2"></i><%= flash.error %></div>
<% } %>

<!-- Stats -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="stat-card">
      <div class="stat-icon" style="background:#fef9c3;"><span>⏳</span></div>
      <div class="stat-lbl">Menunggu</div>
      <div class="stat-val text-warning"><%= stats.pending %></div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="stat-card">
      <div class="stat-icon" style="background:#dcfce7;"><span>✅</span></div>
      <div class="stat-lbl">Disetujui</div>
      <div class="stat-val text-success"><%= stats.approved %></div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="stat-card">
      <div class="stat-icon" style="background:#fee2e2;"><span>❌</span></div>
      <div class="stat-lbl">Ditolak</div>
      <div class="stat-val text-danger"><%= stats.rejected %></div>
    </div>
  </div>
</div>

<!-- Table -->
<div class="data-table">
  <div class="tbl-head">
    <span>Riwayat Pengajuan Saya</span>
    <a href="/pengajuan/baru" class="btn-accent"><i class="bi bi-plus-lg"></i> Buat Pengajuan</a>
  </div>
  <% if (requests.length === 0) { %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-inbox" style="font-size:40px;opacity:.3;"></i>
      <p class="mt-2">Belum ada pengajuan. <a href="/pengajuan/baru">Buat sekarang →</a></p>
    </div>
  <% } else { %>
  <table class="table table-hover">
    <thead>
      <tr>
        <th>#</th><th>Tanggal</th><th>Keperluan</th><th>Kategori</th><th>Jumlah</th><th>Status</th><th>Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% requests.forEach((r, i) => { %>
      <tr>
        <td><span class="text-muted">#<%= r.id %></span></td>
        <td><%= new Date(r.request_date).toLocaleDateString('id-ID', {day:'2-digit',month:'short',year:'numeric'}) %></td>
        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= r.description %>"><%= r.description %></td>
        <td><span class="badge bg-light text-dark border"><%= r.category_name %></span></td>
        <td class="currency">Rp <%= Number(r.amount).toLocaleString('id-ID') %></td>
        <td>
          <% if(r.status==='PENDING') { %><span class="sbadge sbadge-pending">⏳ Menunggu</span>
          <% } else if(r.status==='APPROVED') { %><span class="sbadge sbadge-approved">✅ Disetujui</span>
          <% } else { %><span class="sbadge sbadge-rejected">❌ Ditolak</span><% } %>
        </td>
        <td><a href="/pengajuan/<%= r.id %>" class="btn btn-sm btn-outline-secondary">Lihat</a></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('../partials/footer') %>
