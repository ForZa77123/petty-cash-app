<%- include('../partials/header', { pageTitle: 'Buat Pengajuan Dana', activePage: 'buat' }) %>

<% if (flash.error && flash.error.length > 0) { %>
  <div class="alert-error mb-4"><i class="bi bi-exclamation-circle me-2"></i><%= flash.error %></div>
<% } %>

<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="form-card">
      <h5 class="fw-bold mb-1">Form Pengajuan Dana Kas Kecil</h5>
      <p class="text-muted" style="font-size:13px;">Isi detail pengeluaran dan lampirkan foto bukti nota/struk.</p>
      <hr class="my-3"/>

      <form action="/pengajuan" method="POST" enctype="multipart/form-data">
        <div class="mb-3">
          <label class="form-label">Tanggal Transaksi <span class="text-danger">*</span></label>
          <input type="date" name="request_date" class="form-control"
            value="<%= new Date().toISOString().split('T')[0] %>" required/>
        </div>

        <div class="mb-3">
          <label class="form-label">Kategori Pengeluaran <span class="text-danger">*</span></label>
          <select name="category_id" class="form-select" required>
            <option value="">-- Pilih Kategori --</option>
            <% categories.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.name %> — <span><%= c.description %></span></option>
            <% }) %>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label">Keperluan / Deskripsi <span class="text-danger">*</span></label>
          <textarea name="description" class="form-control" rows="3" placeholder="Contoh: Pembelian kertas A4 dan tinta printer untuk keperluan kantor..." required></textarea>
        </div>

        <div class="mb-3">
          <label class="form-label">Jumlah yang Diajukan (Rp) <span class="text-danger">*</span></label>
          <div class="input-group">
            <span class="input-group-text">Rp</span>
            <input type="number" name="amount" class="form-control" placeholder="150000" min="1" required/>
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label">Foto Bukti Nota / Struk <span class="text-danger">*</span></label>
          <input type="file" name="receipt" class="form-control" accept=".jpg,.jpeg,.png,.pdf" required id="receiptInput"/>
          <div class="form-text text-muted">Format: JPG, PNG, atau PDF. Maks. 5MB.</div>
          <div id="previewBox" class="mt-2" style="display:none;">
            <img id="previewImg" src="" alt="Preview" class="receipt-img"/>
          </div>
        </div>

        <div class="d-flex gap-2">
          <a href="/dashboard" class="btn btn-outline-secondary flex-fill">Batalkan</a>
          <button type="submit" class="btn-accent flex-fill justify-content-center">
            <i class="bi bi-send-fill"></i> Ajukan Sekarang
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
document.getElementById('receiptInput').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (file && file.type.startsWith('image/')) {
    const reader = new FileReader();
    reader.onload = ev => {
      document.getElementById('previewImg').src = ev.target.result;
      document.getElementById('previewBox').style.display = 'block';
    };
    reader.readAsDataURL(file);
  }
});
</script>

<%- include('../partials/footer') %>
