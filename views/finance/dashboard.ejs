<%- include('../partials/header', { pageTitle: 'Dashboard Finance', activePage: 'dashboard' }) %>

<% if (flash.success && flash.success.length > 0) { %>
  <div class="alert-success mb-4"><i class="bi bi-check-circle me-2"></i><%= flash.success %></div>
<% } %>

<!-- Stats -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="stat-card">
      <div class="stat-icon" style="background:#dbeafe;">💰</div>
      <div class="stat-lbl">Saldo Kas Kecil</div>
      <div class="stat-val" style="color:#1d4ed8;font-size:20px;">Rp <%= Number(balance).toLocaleString('id-ID') %></div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="stat-card">
      <div class="stat-icon" style="background:#dcfce7;">⬆️</div>
      <div class="stat-lbl">Total Kas Masuk</div>
      <div class="stat-val text-success" style="font-size:18px;">Rp <%= Number(totalIn).toLocaleString('id-ID') %></div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="stat-card">
      <div class="stat-icon" style="background:#fee2e2;">⬇️</div>
      <div class="stat-lbl">Total Kas Keluar</div>
      <div class="stat-val text-danger" style="font-size:18px;">Rp <%= Number(totalOut).toLocaleString('id-ID') %></div>
    </div>
  </div>
</div>

<!-- Pengajuan Approved — siap dibayar Finance -->
<div class="data-table mb-4">
  <div class="tbl-head">
    <span>💵 Antrian Pembayaran — Sudah Disetujui Manager (<%= toPayRequests.length %>)</span>
    <a href="/finance/pengajuan?status=APPROVED" class="btn btn-sm btn-outline-secondary">Lihat Semua</a>
  </div>
  <% if (toPayRequests.length === 0) { %>
    <div class="text-center py-4 text-muted"><i class="bi bi-check-all" style="font-size:30px;opacity:.3;"></i><p class="mt-2 mb-0">Tidak ada pengajuan yang perlu dibayar saat ini.</p></div>
  <% } else { %>
  <table class="table table-hover">
    <thead><tr><th>#</th><th>Pemohon</th><th>Keperluan</th><th>Jumlah</th><th>Disetujui Manager</th><th>Aksi</th></tr></thead>
    <tbody>
      <% toPayRequests.forEach(r => { %>
      <tr>
        <td><span class="text-muted">#<%= r.id %></span></td>
        <td><strong><%= r.requester_name %></strong></td>
        <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= r.description %></td>
        <td class="currency fw-bold">Rp <%= Number(r.amount).toLocaleString('id-ID') %></td>
        <td><small class="text-muted"><%= r.manager_name || '-' %></small></td>
        <td>
          <a href="/finance/pengajuan/<%= r.id %>" class="btn btn-sm btn-primary">💵 Proses Bayar</a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<!-- Riwayat Pembayaran Terbaru -->
<div class="data-table">
  <div class="tbl-head"><span>📋 Riwayat Pembayaran Terbaru</span></div>
  <table class="table table-hover">
    <thead><tr><th>#</th><th>Pemohon</th><th>Keperluan</th><th>Jumlah</th><th>Status</th></tr></thead>
    <tbody>
      <% recentPaid.forEach(r => { %>
      <tr>
        <td>#<%= r.id %></td>
        <td><%= r.requester_name %></td>
        <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= r.description %></td>
        <td class="currency">Rp <%= Number(r.amount).toLocaleString('id-ID') %></td>
        <td><span class="sbadge" style="background:#d1fae5;color:#065f46;">💵 Sudah Dibayar</span></td>
      </tr>
      <% }) %>
      <% if(recentPaid.length===0) { %><tr><td colspan="5" class="text-center text-muted py-4">Belum ada riwayat pembayaran.</td></tr><% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
