<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Petty Cash System</title>
  <meta name="description" content="Sistem Pengelolaan Kas Kecil Digital"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <style>
    :root {
      --sidebar-bg: #0f1623;
      --sidebar-width: 260px;
      --accent: #6366f1;
      --accent-light: #818cf8;
      --surface: #ffffff;
      --bg: #f1f5f9;
      --text: #1e293b;
      --muted: #64748b;
      --border: #e2e8f0;
    }
    * { box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; }

    /* Sidebar */
    .sidebar {
      width: var(--sidebar-width); height: 100vh; position: fixed; top: 0; left: 0;
      background: var(--sidebar-bg); display: flex; flex-direction: column;
      z-index: 100; transition: transform 0.3s;
    }
    .sidebar-brand {
      padding: 24px 20px 20px; border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .sidebar-brand .brand-icon {
      width: 40px; height: 40px; background: var(--accent);
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
      font-size: 20px; margin-bottom: 10px;
    }
    .sidebar-brand .brand-name { color: #fff; font-weight: 700; font-size: 15px; line-height: 1.2; }
    .sidebar-brand .brand-sub { color: rgba(255,255,255,.4); font-size: 11px; }

    .sidebar-nav { flex: 1; padding: 16px 12px; overflow-y: auto; }
    .nav-label { color: rgba(255,255,255,.3); font-size: 10px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; padding: 8px 8px 4px; }
    .sidebar-link {
      display: flex; align-items: center; gap: 10px; padding: 10px 12px;
      color: rgba(255,255,255,.6); text-decoration: none; border-radius: 8px;
      font-size: 14px; font-weight: 500; transition: all 0.2s; margin-bottom: 2px;
    }
    .sidebar-link:hover, .sidebar-link.active {
      background: rgba(99,102,241,.2); color: #fff;
    }
    .sidebar-link.active { background: var(--accent); color: #fff; }
    .sidebar-link i { font-size: 16px; width: 20px; text-align: center; }

    .sidebar-footer { padding: 16px; border-top: 1px solid rgba(255,255,255,.08); }
    .user-card {
      display: flex; align-items: center; gap: 10px; padding: 10px 12px;
      background: rgba(255,255,255,.05); border-radius: 10px;
    }
    .user-avatar {
      width: 36px; height: 36px; border-radius: 50%; background: var(--accent);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 700; font-size: 14px; flex-shrink: 0;
    }
    .user-name { color: #fff; font-size: 13px; font-weight: 600; }
    .user-role { color: rgba(255,255,255,.4); font-size: 11px; }

    /* Main content */
    .main-content { margin-left: var(--sidebar-width); min-height: 100vh; }
    .topbar {
      background: var(--surface); border-bottom: 1px solid var(--border);
      padding: 14px 28px; display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 99;
    }
    .topbar h1 { font-size: 18px; font-weight: 700; margin: 0; }
    .page-body { padding: 28px; }

    /* Cards */
    .stat-card {
      background: var(--surface); border-radius: 14px; padding: 22px;
      border: 1px solid var(--border); transition: box-shadow 0.2s;
    }
    .stat-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.07); }
    .stat-icon {
      width: 48px; height: 48px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 12px;
    }
    .stat-label { color: var(--muted); font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; }
    .stat-value { font-size: 24px; font-weight: 700; margin-top: 4px; }

    /* Table */
    .data-table { background: var(--surface); border-radius: 14px; border: 1px solid var(--border); overflow: hidden; }
    .data-table .table { margin: 0; }
    .data-table .table thead th {
      background: #f8fafc; color: var(--muted); font-size: 11px; font-weight: 600;
      text-transform: uppercase; letter-spacing: .5px; border-bottom: 1px solid var(--border); padding: 12px 16px;
    }
    .data-table .table tbody td { padding: 12px 16px; vertical-align: middle; border-color: var(--border); font-size: 14px; }
    .data-table .table-section-title { padding: 14px 20px; background: #f8fafc; font-weight: 600; border-bottom: 1px solid var(--border); }

    /* Badges */
    .badge-pending { background: #fef9c3; color: #92400e; }
    .badge-approved { background: #dcfce7; color: #14532d; }
    .badge-rejected { background: #fee2e2; color: #7f1d1d; }
    .badge-masuk { background: #dbeafe; color: #1e3a8a; }
    .badge-keluar { background: #fce7f3; color: #831843; }
    .status-badge {
      padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600;
      display: inline-flex; align-items: center; gap: 4px;
    }

    /* Forms */
    .form-card { background: var(--surface); border-radius: 14px; padding: 28px; border: 1px solid var(--border); }
    .form-label { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
    .form-control, .form-select {
      border: 1.5px solid var(--border); border-radius: 8px; padding: 10px 14px;
      font-size: 14px; transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-control:focus, .form-select:focus {
      border-color: var(--accent); box-shadow: 0 0 0 3px rgba(99,102,241,.15); outline: none;
    }
    .btn-primary-custom {
      background: var(--accent); color: #fff; border: none; padding: 10px 20px;
      border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: all 0.2s;
    }
    .btn-primary-custom:hover { background: #4f46e5; transform: translateY(-1px); }
    .btn-danger-custom {
      background: #ef4444; color: #fff; border: none; padding: 10px 20px;
      border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: all 0.2s;
    }
    .receipt-preview { max-width: 100%; max-height: 300px; border-radius: 10px; border: 2px solid var(--border); }
    .read-only-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: #fef3c7; color: #92400e; padding: 6px 14px; border-radius: 20px;
      font-size: 12px; font-weight: 600;
    }

    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); }
      .main-content { margin-left: 0; }
    }
  </style>
</head>
<body>

<div class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-icon">💰</div>
    <div class="brand-name">Petty Cash System</div>
    <div class="brand-sub">Sistem Kas Kecil Digital</div>
  </div>

  <nav class="sidebar-nav">
    <% if (currentUser) { %>
      <% if (currentUser.role === 'KARYAWAN') { %>
        <div class="nav-label">Menu</div>
        <a href="/dashboard" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
          <i class="bi bi-grid-1x2"></i> Dashboard
        </a>
        <a href="/pengajuan/baru" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'buat' ? 'active' : '' %>">
          <i class="bi bi-plus-circle"></i> Buat Pengajuan
        </a>
      <% } %>

      <% if (currentUser.role === 'FINANCE') { %>
        <div class="nav-label">Menu Finance</div>
        <a href="/finance/dashboard" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
          <i class="bi bi-grid-1x2"></i> Dashboard
        </a>
        <a href="/finance/pengajuan" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'pengajuan' ? 'active' : '' %>">
          <i class="bi bi-file-earmark-text"></i> Semua Pengajuan
        </a>
        <a href="/finance/saldo" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'saldo' ? 'active' : '' %>">
          <i class="bi bi-wallet2"></i> Manajemen Saldo
        </a>
      <% } %>

      <% if (currentUser.role === 'MANAGER') { %>
        <div class="nav-label">Laporan</div>
        <a href="/manager/dashboard" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
          <i class="bi bi-grid-1x2"></i> Dashboard
        </a>
        <a href="/manager/laporan" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'laporan' ? 'active' : '' %>">
          <i class="bi bi-bar-chart-line"></i> Laporan Kas
        </a>
      <% } %>

      <% if (currentUser.role === 'ADMIN') { %>
        <div class="nav-label">Administrasi</div>
        <a href="/admin/users" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'users' ? 'active' : '' %>">
          <i class="bi bi-people"></i> Manajemen User
        </a>
        <a href="/admin/users/baru" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'user-baru' ? 'active' : '' %>">
          <i class="bi bi-person-plus"></i> Tambah User
        </a>
      <% } %>
    <% } %>
  </nav>

  <div class="sidebar-footer">
    <% if (currentUser) { %>
    <div class="user-card">
      <div class="user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
      <div class="flex-1">
        <div class="user-name"><%= currentUser.name.split(' ')[0] %></div>
        <div class="user-role"><%= currentUser.role %></div>
      </div>
    </div>
    <form action="/logout" method="POST" class="mt-2">
      <button type="submit" class="w-100 btn btn-sm" style="background:rgba(255,255,255,.08);color:rgba(255,255,255,.6);border:none;border-radius:8px;padding:8px;">
        <i class="bi bi-box-arrow-left"></i> Logout
      </button>
    </form>
    <% } %>
  </div>
</div>

<div class="main-content">
  <div class="topbar">
    <h1><%- typeof pageTitle !== 'undefined' ? pageTitle : 'Dashboard' %></h1>
    <div class="d-flex align-items-center gap-2">
      <% if (currentUser && currentUser.role === 'MANAGER') { %>
        <span class="read-only-badge"><i class="bi bi-eye"></i> Mode Hanya Baca</span>
      <% } %>
      <span class="badge bg-light text-dark border" style="font-size:12px;">
        <i class="bi bi-person-circle me-1"></i><%= currentUser ? currentUser.name : '' %>
      </span>
    </div>
  </div>

  <div class="page-body">
    <%- body %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
