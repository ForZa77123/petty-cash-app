<%- include('../partials/header', { pageTitle: 'Audit Detail Pengajuan #' + request.id, activePage: 'pengajuan' }) %>

<div class="row">
  <div class="col-lg-7">
    <div class="mb-3 d-flex gap-2">
      <a href="/auditor/pengajuan" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i> Kembali</a>
      <span class="ro-badge"><i class="bi bi-shield-check"></i> Audit View — Read Only</span>
    </div>

    <div class="form-card">
      <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
          <h5 class="fw-bold mb-1">Pengajuan #<%= request.id %></h5>
          <p class="text-muted mb-0" style="font-size:12px;">Diajukan oleh <strong><%= request.requester_name %></strong></p>
        </div>
        <% if(request.status==='PENDING') { %><span class="sbadge sbadge-pending" style="padding:6px 14px;font-size:13px;">⏳ Menunggu</span>
        <% } else if(request.status==='APPROVED') { %><span class="sbadge sbadge-approved" style="padding:6px 14px;font-size:13px;">✅ Disetujui</span>
        <% } else { %><span class="sbadge sbadge-rejected" style="padding:6px 14px;font-size:13px;">❌ Ditolak</span><% } %>
      </div>
      <hr/>

      <div class="detail-row"><div class="detail-label">Pemohon</div><div class="detail-val"><%= request.requester_name %></div></div>
      <div class="detail-row"><div class="detail-label">Tanggal Transaksi</div><div class="detail-val"><%= new Date(request.request_date).toLocaleDateString('id-ID', {day:'2-digit',month:'long',year:'numeric'}) %></div></div>
      <div class="detail-row"><div class="detail-label">Kategori</div><div class="detail-val"><span class="badge bg-light text-dark border"><%= request.category_name %></span></div></div>
      <div class="detail-row"><div class="detail-label">Keperluan</div><div class="detail-val"><%= request.description %></div></div>
      <div class="detail-row"><div class="detail-label">Jumlah</div><div class="detail-val currency fw-bold" style="font-size:17px;">Rp <%= Number(request.amount).toLocaleString('id-ID') %></div></div>
      <div class="detail-row"><div class="detail-label">Dibuat Pada</div><div class="detail-val text-muted"><%= new Date(request.created_at).toLocaleString('id-ID') %></div></div>

      <!-- Audit Trail Section -->
      <div class="mt-4 p-3 rounded" style="background:#f8fafc;border:1px solid #e2e8f0;">
        <p class="fw-bold mb-3" style="font-size:13px;color:#475569;">🔍 Audit Trail</p>
        <div class="detail-row" style="border-color:#e2e8f0;"><div class="detail-label">Status Akhir</div>
          <div class="detail-val">
            <% if(request.status==='PENDING') { %><span class="sbadge sbadge-pending">⏳ Menunggu</span>
            <% } else if(request.status==='APPROVED') { %><span class="sbadge sbadge-approved">✅ Disetujui</span>
            <% } else { %><span class="sbadge sbadge-rejected">❌ Ditolak</span><% } %>
          </div>
        </div>
        <% if(request.reviewer_name) { %>
        <div class="detail-row" style="border-color:#e2e8f0;"><div class="detail-label">Diproses Oleh</div><div class="detail-val"><strong><%= request.reviewer_name %></strong> <span class="badge bg-light text-dark border ms-1" style="font-size:10px;"><%= request.reviewer_role %></span></div></div>
        <div class="detail-row" style="border-color:#e2e8f0;"><div class="detail-label">Waktu Diproses</div><div class="detail-val text-muted"><%= new Date(request.reviewed_at).toLocaleString('id-ID') %></div></div>
        <% } else { %>
        <div class="detail-row" style="border-color:#e2e8f0;"><div class="detail-label">Diproses Oleh</div><div class="detail-val text-muted fst-italic">Belum diproses</div></div>
        <% } %>
        <% if(request.rejection_note) { %>
        <div class="detail-row" style="border-color:#e2e8f0;border-bottom:none;"><div class="detail-label">Alasan Penolakan</div><div class="detail-val text-danger"><%= request.rejection_note %></div></div>
        <% } %>
      </div>

      <!-- Receipt -->
      <div class="mt-4">
        <p class="fw-bold mb-2" style="font-size:13px;">Bukti Nota / Struk:</p>
        <% if(request.receipt_image_path && !request.receipt_image_path.startsWith('sample/')) { %>
          <img src="<%= request.receipt_image_path.startsWith('data:image') ? request.receipt_image_path : '/uploads/' + request.receipt_image_path %>" alt="Bukti Nota" class="receipt-img"/>
        <% } else { %>
          <div class="p-4 text-center bg-light rounded" style="border:2px dashed #e2e8f0;">
            <i class="bi bi-image" style="font-size:32px;color:#cbd5e1;"></i>
            <p class="text-muted mt-2 mb-0" style="font-size:12px;">Preview bukti nota</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
