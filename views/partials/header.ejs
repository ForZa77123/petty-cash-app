<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= typeof pageTitle !=='undefined' ? pageTitle + ' — ' : '' %>Petty Cash System
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <style>
    :root {
      --sidebar-bg: #0f1623;
      --sidebar-w: 260px;
      --accent: #6366f1;
      --bg: #f1f5f9;
      --surface: #fff;
      --border: #e2e8f0;
      --muted: #64748b;
      --text: #1e293b;
    }

    * {
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      margin: 0;
    }

    .sidebar {
      width: var(--sidebar-w);
      height: 100vh;
      position: fixed;
      top: 0;
      left: 0;
      background: var(--sidebar-bg);
      display: flex;
      flex-direction: column;
      z-index: 100;
    }

    .sb-brand {
      padding: 22px 20px 18px;
      border-bottom: 1px solid rgba(255, 255, 255, .08);
    }

    .sb-icon {
      width: 38px;
      height: 38px;
      background: var(--accent);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      margin-bottom: 8px;
    }

    .sb-name {
      color: #979696;
      font-weight: 700;
      font-size: 12px;
    }

    .sb-sub {
      color: #fff;
      font-size: 14px;
    }

    .sb-nav {
      flex: 1;
      padding: 14px 12px;
      overflow-y: auto;
    }

    .nav-lbl {
      color: rgba(255, 255, 255, .3);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 8px 8px 4px;
    }

    .sb-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      color: rgba(255, 255, 255, .6);
      text-decoration: none;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      transition: all .2s;
      margin-bottom: 2px;
    }

    .sb-link:hover {
      background: rgba(99, 102, 241, .2);
      color: #fff;
    }

    .sb-link.active {
      background: var(--accent);
      color: #fff;
    }

    .sb-link i {
      font-size: 15px;
      width: 18px;
      text-align: center;
    }

    .sb-footer {
      padding: 14px;
      border-top: 1px solid rgba(255, 255, 255, .08);
    }

    .u-card {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      background: rgba(255, 255, 255, .05);
      border-radius: 10px;
    }

    .u-avatar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
      font-size: 13px;
      flex-shrink: 0;
    }

    .u-name {
      color: #fff;
      font-size: 13px;
      font-weight: 600;
      line-height: 1.2;
    }

    .u-role {
      color: rgba(255, 255, 255, .4);
      font-size: 10px;
    }

    .main {
      margin-left: var(--sidebar-w);
      min-height: 100vh;
    }

    .topbar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 13px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 99;
    }

    .topbar h1 {
      font-size: 17px;
      font-weight: 700;
      margin: 0;
    }

    .page-body {
      padding: 24px;
    }

    .stat-card {
      background: var(--surface);
      border-radius: 14px;
      padding: 20px;
      border: 1px solid var(--border);
      height: 100%;
    }

    .stat-icon {
      width: 46px;
      height: 46px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      margin-bottom: 10px;
    }

    .stat-lbl {
      color: var(--muted);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .5px;
    }

    .stat-val {
      font-size: 22px;
      font-weight: 700;
      margin-top: 4px;
    }

    .data-table {
      background: var(--surface);
      border-radius: 14px;
      border: 1px solid var(--border);
      overflow: hidden;
    }

    .data-table table {
      margin: 0;
    }

    .data-table thead th {
      background: #f8fafc;
      color: var(--muted);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .5px;
      border-bottom: 1px solid var(--border);
      padding: 11px 16px;
    }

    .data-table tbody td {
      padding: 11px 16px;
      vertical-align: middle;
      border-color: var(--border);
      font-size: 13px;
    }

    .tbl-head {
      padding: 14px 20px;
      background: #f8fafc;
      font-weight: 700;
      font-size: 14px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .sbadge {
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    .sbadge-pending {
      background: #fef9c3;
      color: #92400e;
    }

    .sbadge-approved {
      background: #dcfce7;
      color: #14532d;
    }

    .sbadge-rejected {
      background: #fee2e2;
      color: #7f1d1d;
    }

    .sbadge-masuk {
      background: #dbeafe;
      color: #1e3a8a;
    }

    .sbadge-keluar {
      background: #fce7f3;
      color: #831843;
    }

    .form-card {
      background: var(--surface);
      border-radius: 14px;
      padding: 26px;
      border: 1px solid var(--border);
    }

    .form-label {
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 5px;
    }

    .form-control,
    .form-select {
      border: 1.5px solid var(--border);
      border-radius: 8px;
      padding: 9px 13px;
      font-size: 13px;
    }

    .form-control:focus,
    .form-select:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(99, 102, 241, .15);
      outline: none;
    }

    .btn-accent {
      background: var(--accent);
      color: #fff;
      border: none;
      padding: 9px 20px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 13px;
      cursor: pointer;
      transition: all .2s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .btn-accent:hover {
      background: #4f46e5;
      transform: translateY(-1px);
      color: #fff;
    }

    .btn-danger {
      background: #ef4444;
      color: #fff;
      border: none;
      padding: 9px 20px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 13px;
      cursor: pointer;
      transition: all .2s;
    }

    .btn-danger:hover {
      background: #dc2626;
    }

    .btn-success {
      background: #22c55e;
      color: #fff;
      border: none;
      padding: 9px 20px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 13px;
      cursor: pointer;
      transition: all .2s;
    }

    .btn-success:hover {
      background: #16a34a;
    }

    .receipt-img {
      max-width: 100%;
      max-height: 280px;
      border-radius: 10px;
      border: 2px solid var(--border);
    }

    .ro-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: #fef3c7;
      color: #92400e;
      padding: 5px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
    }

    .alert-success {
      background: #f0fdf4;
      border: 1px solid #86efac;
      color: #14532d;
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 13px;
    }

    .alert-error {
      background: #fef2f2;
      border: 1px solid #fca5a5;
      color: #7f1d1d;
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 13px;
    }

    .currency {
      font-family: 'Inter', sans-serif;
      font-weight: 600;
    }

    .detail-row {
      display: flex;
      gap: 8px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
    }

    .detail-label {
      color: var(--muted);
      font-size: 12px;
      font-weight: 600;
      min-width: 140px;
    }

    .detail-val {
      font-size: 13px;
      font-weight: 500;
    }
  </style>
</head>

<body>
  <div class="sidebar">
    <div class="sb-brand">
      <div class="sb-icon">💰</div>
      <div class="sb-sub">PT Sinergi Artha Mandiri</div>
      <div class="sb-name">Petty Cash System</div>
    </div>
    <nav class="sb-nav">
      <% if (user.role==='KARYAWAN' ) { %>
        <div class="nav-lbl">Menu Utama</div>
        <a href="/dashboard" class="sb-link <%= activePage==='dashboard'?'active':'' %>"><i
            class="bi bi-grid-1x2-fill"></i> Dashboard</a>
        <a href="/pengajuan/baru" class="sb-link <%= activePage==='buat'?'active':'' %>"><i
            class="bi bi-plus-circle-fill"></i> Buat Pengajuan</a>
        <% } %>
          <% if (user.role==='FINANCE' ) { %>
            <div class="nav-lbl">Menu Finance</div>
            <a href="/finance/dashboard" class="sb-link <%= activePage==='dashboard'?'active':'' %>"><i
                class="bi bi-grid-1x2-fill"></i> Dashboard</a>
            <a href="/finance/pengajuan" class="sb-link <%= activePage==='pengajuan'?'active':'' %>"><i
                class="bi bi-file-earmark-text-fill"></i> Semua Pengajuan</a>
            <a href="/finance/saldo" class="sb-link <%= activePage==='saldo'?'active':'' %>"><i
                class="bi bi-wallet2"></i> Manajemen Saldo</a>
            <% } %>
              <% if (user.role==='MANAGER' ) { %>
                <div class="nav-lbl">Persetujuan</div>
                <a href="/manager/dashboard" class="sb-link <%= activePage==='dashboard'?'active':'' %>"><i
                    class="bi bi-grid-1x2-fill"></i> Dashboard</a>
                <a href="/manager/pengajuan" class="sb-link <%= activePage==='pengajuan'?'active':'' %>"><i
                    class="bi bi-check2-square"></i> Kelola Pengajuan</a>
                <a href="/manager/laporan" class="sb-link <%= activePage==='laporan'?'active':'' %>"><i
                    class="bi bi-bar-chart-fill"></i> Laporan Kas</a>
                <% } %>
                  <% if (user.role==='AUDITOR' ) { %>
                    <div class="nav-lbl">Audit</div>
                    <a href="/auditor/dashboard" class="sb-link <%= activePage==='dashboard'?'active':'' %>"><i
                        class="bi bi-grid-1x2-fill"></i> Dashboard</a>
                    <a href="/auditor/pengajuan" class="sb-link <%= activePage==='pengajuan'?'active':'' %>"><i
                        class="bi bi-file-earmark-text-fill"></i> Semua Pengajuan</a>
                    <a href="/auditor/mutasi" class="sb-link <%= activePage==='mutasi'?'active':'' %>"><i
                        class="bi bi-journal-text"></i> Ledger / Mutasi</a>
                    <% } %>
                      <% if (user.role==='ADMIN' ) { %>
                        <div class="nav-lbl">Administrasi</div>
                        <a href="/admin/users" class="sb-link <%= activePage==='users'?'active':'' %>"><i
                            class="bi bi-people-fill"></i> Manajemen User</a>
                        <a href="/admin/users/baru" class="sb-link <%= activePage==='user-baru'?'active':'' %>"><i
                            class="bi bi-person-plus-fill"></i> Tambah User</a>
                        <% } %>
    </nav>
    <div class="sb-footer">
      <div class="u-card">
        <div class="u-avatar">
          <%= user.name.charAt(0).toUpperCase() %>
        </div>
        <div>
          <div class="u-name">
            <%= user.name.split(' ')[0] %></div><div class="u-role"><%= user.role %></div></div>
    </div>
    <form action="/logout" method="POST" class="mt-2">
      <button type="submit" style="width:100%;background:rgba(255,255,255,.07);color:rgba(255,255,255,.5);border:none;border-radius:8px;padding:7px;font-size:13px;cursor:pointer;">
        <i class="bi bi-box-arrow-left"></i> Logout
      </button>
    </form>
  </div>
</div>
<div class="main">
  <div class="topbar">
    <h1><%= pageTitle %></h1>
    <div class="d-flex align-items-center gap-2">
      <% if (user.role === 'MANAGER') { %><span class="ro-badge"><i class="bi bi-check2-square"></i> Approval Mode</span>
              <% } %>
                <span class="badge bg-light text-dark border" style="font-size:11px;"><i
                    class="bi bi-person-circle me-1"></i>
                  <%= user.name %>
                </span>
          </div>
        </div>
        <div class="page-body">